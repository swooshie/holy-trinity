PORT=3001

# Keep false for normal local development. Routes still accept {"fixture": true}.
AGENTIFY_FIXTURE_MODE=false

# Default path for no-key demos.
AGENTIFY_TRUST_MODE=deterministic
AGENTIFY_CHAT_MODE=deterministic
AGENTIFY_EXECUTE_TOOLS=false

# Deterministic demo IDs.
DEMO_TRUSTED_AGENT_ID=trusted-agent
DEMO_UNTRUSTED_AGENT_ID=untrusted-agent

# Live mode only. Leave blank for fallback demos.
VALIRON_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
TARGET_API_KEY=
