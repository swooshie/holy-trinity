PORT=3001
NODE_ENV=development

# Set to true to use deterministic fixture behavior for trust + parsing + generation + chat.
DEMO_FALLBACK_MODE=true

# Optional Anthropic key for real chat proxy mode.
ANTHROPIC_API_KEY=

# Optional Valiron key if your SDK setup requires it.
VALIRON_API_KEY=

# Optional default agent id when caller does not pass x-agent-id.
DEFAULT_AGENT_ID=

# Optional allow-list for deterministic trusted stubs.
# Example: TRUSTED_AGENT_IDS=25459,trusted-demo
TRUSTED_AGENT_IDS=25459,trusted-demo
